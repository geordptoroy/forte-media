# FORTE MEDIA - Production Environment Variables
# Copy this file to .env.production and fill in the actual values

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DB_ROOT_PASSWORD=your-secure-root-password-here
DB_NAME=forte_media
DB_USER=forte_user
DB_PASSWORD=your-secure-db-password-here

# ============================================================================
# SECURITY KEYS (MUST BE CHANGED IN PRODUCTION)
# ============================================================================
# Encryption key for storing Meta API credentials (AES-256-GCM)
# Must be exactly 32 characters long
ENCRYPTION_KEY=your-32-character-encryption-key-here

# Session secret for JWT and session management
# Generate with: openssl rand -base64 32
SESSION_SECRET=your-secure-session-secret-here

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ============================================================================
# CORS AND SECURITY
# ============================================================================
# Frontend URL for CORS configuration
CORS_ORIGIN=https://your-domain.com

# Cookie security settings (should be true in production)
COOKIE_SECURE=true
COOKIE_SAME_SITE=strict
COOKIE_HTTP_ONLY=true

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
# API URL for frontend to communicate with backend
VITE_API_URL=https://api.your-domain.com

# ============================================================================
# OPTIONAL: MONITORING AND LOGGING
# ============================================================================
# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================================================
# OPTIONAL: EXTERNAL SERVICES
# ============================================================================
# Email service for notifications (optional)
# SMTP_HOST=smtp.your-email-provider.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-email-password

# ============================================================================
# NOTES
# ============================================================================
# 1. ENCRYPTION_KEY: Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# 2. SESSION_SECRET: Generate with: openssl rand -base64 32
# 3. DB_PASSWORD: Use a strong password with special characters
# 4. CORS_ORIGIN: Set to your production domain
# 5. VITE_API_URL: Set to your production API URL
# 6. Never commit this file with actual values to version control
# 7. Store sensitive values in a secrets manager (AWS Secrets Manager, Vault, etc.)
