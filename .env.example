# --- CONFIGURAÇÕES GERAIS ---
NODE_ENV=development
PORT=3000
JWT_SECRET=supersecretjwt_mude_isso_em_producao

# --- BANCO DE DADOS ---
DB_HOST=mysql
DB_PORT=3306
DB_USER=forte_user
DB_PASSWORD=forte_password
DB_NAME=forte_media

# --- SWITCH MOCK / REAL ---
# Defina como 'false' para usar a API real da Meta e o banco de dados real
USE_MOCK=false
VITE_USE_MOCK=false

# --- META API (OBRIGATÓRIO SE USE_MOCK=false) ---
# Obtenha estas credenciais em https://developers.facebook.com/
META_API_KEY=seu_access_token_de_longa_duracao
META_APP_ID=seu_app_id
META_APP_SECRET=seu_app_secret
ENCRYPTION_KEY=default-key-change-in-production-32chars

# --- CONFIGURAÇÕES DE PRODUÇÃO ---
FRONTEND_URL=https://localhost
BACKEND_URL=https://localhost/api

# --- CERTIFICADOS SSL (PARA DOCKER) ---
# Gere com: openssl req -x509 -newkey rsa:4096 -keyout nginx/certs/server.key -out nginx/certs/server.crt -days 365 -nodes
