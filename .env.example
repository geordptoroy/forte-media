# --- CONFIGURAÇÕES GERAIS ---
NODE_ENV=production
PORT=4000
SESSION_SECRET=supersecret_mude_isso_em_producao
ENCRYPTION_KEY=default-key-change-in-production-32chars

# --- BANCO DE DADOS (DOCKER) ---
DB_USER=forte_user
DB_PASSWORD=forte_password
DB_NAME=forte_media
DB_ROOT_PASSWORD=root-password

# --- META API ---
# Obtenha estas credenciais em https://developers.facebook.com/
VITE_APP_ID=seu_app_id

# --- ANALYTICS (OPCIONAL) ---
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# --- CONFIGURAÇÕES DE URL ---
FRONTEND_URL=https://localhost
BACKEND_URL=https://localhost/api
VITE_API_URL=http://localhost:4000
